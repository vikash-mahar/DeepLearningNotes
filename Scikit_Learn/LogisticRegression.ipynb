    "from sklearn.linear_model import LogisticRegression\n",
    "\n",
    "X=[[1],[2],[3],[4],[5]]\n",
    "y=[0,0,1,1,0]\n",
    "model = LogisticRegression()\n",
    "model.fit(X,y)\n",
    "hours = float(input('Enter hours'))\n",
    "result= model.predict([[hours]])[0]\n",
    "\n",
    "if result  ==1:\n",
    "    print(\"Pass\")\n",
    "else:\n",
    "    print(\"false\")"
   ]
