    "from sklearn.linear_model import LinearRegression\n",
    "\n",
    "X=[[1],[2],[3],[4],[5]]\n",
    "y=[40,50,65,70,75]\n",
    "\n",
    "model= LinearRegression()\n",
    "model.fit(X,y)\n",
    "hours=float(input(\"Enter Marks\"))\n",
    "predicted_marks= model.predict([[hours]])\n",
    "print(predicted_marks)"
   ]
